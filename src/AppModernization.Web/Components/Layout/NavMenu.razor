@rendermode InteractiveServer
@inject Services.MigrationStateService StateService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🚀 App Modernization</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="projects">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Projects
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        @if (StateService.CurrentProject is not null)
        {
            <div class="px-3 mt-2 mb-1">
                <small class="text-white-50" style="font-size: 0.7rem;">📂 @StateService.CurrentProject.Name</small>
            </div>
        }

        <h6 class="px-3 mt-2 mb-1 text-muted">Phase 0 — Discovery</h6>

        @foreach (var phase in _discoveryPhases)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link d-flex justify-content-between align-items-center" href="@phase.Route.TrimStart('/')">
                    <span>@GetPhaseIcon(phase) @phase.Name</span>
                    @if (phase.Status != PhaseStatus.NotStarted)
                    {
                        <span class="badge @GetNavBadgeClass(phase)" style="font-size: 0.6rem;">@GetNavBadgeText(phase)</span>
                    }
                </NavLink>
            </div>
        }

        <h6 class="px-3 mt-3 mb-1 text-muted">Migration Phases</h6>

        @foreach (var phase in _migrationPhases)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link d-flex justify-content-between align-items-center" href="@phase.Route.TrimStart('/')">
                    <span>@GetPhaseIcon(phase) @phase.PhaseNumber. @phase.Name</span>
                    @if (phase.Status != PhaseStatus.NotStarted)
                    {
                        <span class="badge @GetNavBadgeClass(phase)" style="font-size: 0.6rem;">@GetNavBadgeText(phase)</span>
                    }
                </NavLink>
            </div>
        }

        <h6 class="px-3 mt-3 mb-1 text-muted">Tools</h6>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="reports">
                📊 Reports
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private List<PhaseInfo> _discoveryPhases = new();
    private List<PhaseInfo> _migrationPhases = new();

    protected override void OnInitialized()
    {
        var phases = StateService.GetPhases();
        _discoveryPhases = phases.Where(p => p.PhaseNumber == 0).ToList();
        _migrationPhases = phases.Where(p => p.PhaseNumber > 0).ToList();
    }

    private static string GetPhaseIcon(PhaseInfo phase) => phase.Id switch
    {
        "phase0-discover" => "🔍",
        "phase0-specify" => "📋",
        "phase0-validate" => "✅",
        "phase1-plan" => "📝",
        "phase2-assess" => "🔬",
        "phase3-migrate" => "⚡",
        "phase4-infra" => "🏗️",
        "phase5-deploy" => "🚀",
        "phase6-cicd" => "🔄",
        _ => "▪️"
    };

    private static string GetNavBadgeClass(PhaseInfo phase) => phase.Status switch
    {
        PhaseStatus.Completed => "bg-success",
        PhaseStatus.InProgress => "bg-primary",
        PhaseStatus.Skipped => "bg-secondary",
        _ => "bg-light text-muted"
    };

    private static string GetNavBadgeText(PhaseInfo phase) => phase.Status switch
    {
        PhaseStatus.Completed => "✓",
        PhaseStatus.InProgress => "Active",
        PhaseStatus.Skipped => "Skip",
        _ => ""
    };
}
