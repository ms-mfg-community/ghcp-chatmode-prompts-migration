@page "/phase0/validate"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 0: Validate — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>✅ QA Validation Phase</h5>
                <p>
                    This phase reviews all extracted artifacts for gaps, missing edge cases, and
                    inconsistencies. The validation assistant will cross-reference discovery outputs
                    with specifications to ensure nothing was lost in translation.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Validation Checklist</h6>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">🔲 Requirements completeness</li>
                        <li class="list-group-item">🔲 Field spec accuracy</li>
                        <li class="list-group-item">🔲 User story quality</li>
                        <li class="list-group-item">🔲 Process map consistency</li>
                        <li class="list-group-item">🔲 Cross-reference validation</li>
                    </ul>
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Use the chat panel on the right to interact with the validation assistant.
                        Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/phase0/specify" class="btn btn-outline-secondary">← Previous</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;

    protected override async Task OnInitializedAsync()
    {
        if (StateService.CurrentProject is null)
        {
            if (!await StateService.EnsureProjectLoadedAsync())
            {
                Navigation.NavigateTo("/");
                return;
            }
        }

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase0-validate");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        // Check if validation report exists — auto-complete if phase is still InProgress
        if (_phase?.Status == PhaseStatus.InProgress && AllReportsExist())
        {
            await StateService.CompletePhaseAsync(_phase.Id);
        }

        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        var reportsPath = StateService.GetCurrentProjectReportsPath();
        var reportsDir = reportsPath ?? "reports";
        var slug = StateService.GetProjectSlug();

        // Check ALL upstream artifacts (discovery + specify = 6 files)
        var upstreamReports = new[]
        {
            $"{slug}-Legacy-Discovery-Report.md",
            $"{slug}-Business-Requirements.md",
            $"{slug}-Process-Maps.md",
            $"{slug}-Field-Specifications.md",
            $"{slug}-User-Stories.md",
            $"{slug}-Data-Dictionary.md"
        };
        var missingUpstream = new List<string>();
        if (reportsPath is not null)
        {
            foreach (var report in upstreamReports)
            {
                var path = System.IO.Path.Combine(reportsPath, report);
                if (!System.IO.File.Exists(path))
                    missingUpstream.Add(report);
            }
        }
        else
        {
            missingUpstream.AddRange(upstreamReports);
        }

        if (missingUpstream.Count > 0)
        {
            // Determine which phases are incomplete
            var missingPhases = new List<string>();
            if (missingUpstream.Any(r => r.Contains("Legacy-Discovery") || r.Contains("Business-Requirements") || r.Contains("Process-Maps")))
                missingPhases.Add("Discover");
            if (missingUpstream.Any(r => r.Contains("Field-Specifications") || r.Contains("User-Stories") || r.Contains("Data-Dictionary")))
                missingPhases.Add("Specify");

            _autoPrompt = "⚠️ The Validate phase depends on upstream reports that have not been generated yet.\n\n" +
                "Missing reports:\n" +
                string.Join("\n", missingUpstream.Select(r => $"- ❌ {r}")) + "\n\n" +
                $"Please tell the user to go back and complete the **{string.Join("** and **", missingPhases)}** phase(s) first before running Validate.";
            return;
        }

        // Check own output: validation report
        var validationReport = $"{slug}-Validation-Report.md";
        var validationPath = System.IO.Path.Combine(reportsPath!, validationReport);

        if (System.IO.File.Exists(validationPath))
        {
            // Validation report already exists — review/refine
            _autoPrompt = $"The validation phase has already been completed.\n\n" +
                $"The following report exists in {reportsDir}/:\n" +
                $"- {validationReport}\n\n" +
                "Review the existing validation report and provide a brief summary of key findings. " +
                "If the user asks, you can refine or regenerate the report.";
        }
        else
        {
            // All upstream exists, no validation report — full validation
            _autoPrompt = "Validate all Phase 0 artifacts for completeness and accuracy:\n" +
                $"1. Read all reports in the {reportsDir}/ directory\n" +
                "2. Check requirements completeness, field spec accuracy, user story quality\n" +
                "3. Identify missing edge cases, validation gaps, and logic inconsistencies\n" +
                $"4. Generate {reportsDir}/{slug}-Validation-Report.md with findings\n" +
                "5. Include a 'Questions for SMEs' section for items that need human review";
        }
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase1/plan");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase1/plan");
    }

    private bool AllReportsExist()
    {
        var reportsPath = StateService.GetCurrentProjectReportsPath();
        if (reportsPath is null) return false;

        var slug = StateService.GetProjectSlug();
        var expected = new[] { $"{slug}-Validation-Report.md" };
        return expected.All(f => System.IO.File.Exists(System.IO.Path.Combine(reportsPath, f)));
    }
}
