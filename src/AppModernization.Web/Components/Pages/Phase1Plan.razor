@page "/phase1/plan"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 1: Plan Migration — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>📐 Migration Planning</h5>
                <p>
                    Configure your target architecture and technology choices. These selections will
                    guide the assessment, code migration, and infrastructure generation phases.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title mb-3">Target Configuration</h6>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hosting Platform</label>
                        <select class="form-select" @bind="StateService.CurrentProject!.HostingPlatform">
                            <option value="">— Select —</option>
                            <option value="App Service">App Service</option>
                            <option value="AKS">AKS</option>
                            <option value="Container Apps">Container Apps</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">IaC Type</label>
                        <select class="form-select" @bind="StateService.CurrentProject!.IaCType">
                            <option value="">— Select —</option>
                            <option value="Bicep">Bicep</option>
                            <option value="Terraform">Terraform</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Database</label>
                        <select class="form-select" @bind="StateService.CurrentProject!.DatabaseType">
                            <option value="">— Select —</option>
                            <option value="Azure SQL">Azure SQL</option>
                            <option value="Cosmos DB">Cosmos DB</option>
                            <option value="PostgreSQL">PostgreSQL</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Framework</label>
                        <select class="form-select" @bind="StateService.CurrentProject!.TargetFramework">
                            <option value="">— Select —</option>
                            <option value=".NET 10">.NET 10</option>
                            <option value=".NET 8">.NET 8</option>
                            <option value="Java 21">Java 21</option>
                            <option value="Java 17">Java 17</option>
                        </select>
                    </div>

                    <button class="btn btn-primary" @onclick="SaveConfiguration">
                        💾 Save Configuration
                    </button>

                    @if (_saved)
                    {
                        <span class="text-success ms-2">✓ Saved</span>
                    }
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Configure your target settings above, then use the chat panel to refine your
                        migration plan. Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/dashboard" class="btn btn-outline-secondary">← Dashboard</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;
    private bool _saved;

    protected override async Task OnInitializedAsync()
    {
        if (StateService.CurrentProject is null)
        {
            if (!await StateService.EnsureProjectLoadedAsync())
            {
                Navigation.NavigateTo("/");
                return;
            }
        }

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase1-plan");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private void SaveConfiguration()
    {
        _saved = true;
        StateHasChanged();
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        var reportsPath = StateService.GetCurrentProjectReportsPath();
        var reportsDir = reportsPath ?? "reports";
        var slug = StateService.GetProjectSlug();
        var sourcePath = StateService.CurrentProject?.SourcePath;
        if (!string.IsNullOrWhiteSpace(sourcePath))
        {
            _autoPrompt = $"Help me plan the migration for the application at: {sourcePath}\n" +
                $"Review any existing Phase 0 discovery reports in the {reportsDir}/ directory (filenames are prefixed with {slug}-).\n" +
                "I need to decide on: hosting platform, IaC type, database, and target framework.\n" +
                "Guide me through these decisions.";
        }
        else
        {
            _autoPrompt = "Help me plan the migration for the application.\n" +
                $"Review any existing Phase 0 discovery reports in the {reportsDir}/ directory (filenames are prefixed with {slug}-).\n" +
                "I need to decide on: hosting platform, IaC type, database, and target framework.\n" +
                "Guide me through these decisions.";
        }
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase2/assess");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase2/assess");
    }
}
