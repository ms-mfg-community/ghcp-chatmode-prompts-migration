@page "/phase4/infra"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 4: Generate Infrastructure — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>🏗️ Infrastructure Generation</h5>
                <p>
                    This phase generates Infrastructure as Code for your target Azure environment.
                    The assistant will create all necessary resource definitions based on your
                    migration plan configuration.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(StateService.CurrentProject?.IaCType))
            {
                <div class="alert alert-info mb-4">
                    <strong>IaC Type:</strong> @StateService.CurrentProject!.IaCType
                </div>
            }

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Infrastructure Components</h6>
                    <ul class="mb-0">
                        <li>Compute (@(StateService.CurrentProject?.HostingPlatform ?? "App Service / AKS / Container Apps"))</li>
                        <li>Monitoring (App Insights + Log Analytics)</li>
                        <li>Database (@(StateService.CurrentProject?.DatabaseType ?? "as configured"))</li>
                        <li>Identity &amp; Security</li>
                        <li>Networking</li>
                        <li>Key Vault</li>
                    </ul>
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Use the chat panel on the right to interact with the infrastructure assistant.
                        Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/phase3/migrate" class="btn btn-outline-secondary">← Previous</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;

    protected override async Task OnInitializedAsync()
    {
        if (StateService.CurrentProject is null)
        {
            if (!await StateService.EnsureProjectLoadedAsync())
            {
                Navigation.NavigateTo("/");
                return;
            }
        }

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase4-infra");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        var reportsPath = StateService.GetCurrentProjectReportsPath();
        var reportsDir = reportsPath ?? "reports";
        var slug = StateService.GetProjectSlug();
        _autoPrompt = "Generate Infrastructure as Code for the migrated application.\n" +
            $"Read the assessment and planning reports in {reportsDir}/ for context (filenames are prefixed with {slug}-).\n" +
            "Create Bicep/Terraform files in the infra/ directory.\n" +
            "Include compute, monitoring, database, identity, and networking modules.";
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase5/deploy");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase5/deploy");
    }
}
