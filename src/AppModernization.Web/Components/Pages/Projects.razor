@page "/projects"
@rendermode InteractiveServer
@inject Services.ProjectPersistenceService PersistenceService
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Projects — App Modernization</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📁 Projects</h2>
        <a href="/" class="btn btn-primary">+ New Project</a>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
        </div>
    }
    else if (_projects.Any())
    {
        <div class="row g-3">
            @foreach (var project in _projects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@project.Name</h5>
                            <p class="text-muted small mb-2">Created @project.CreatedAt.ToString("MMM d, yyyy")</p>
                            @if (project.SourcePath is not null)
                            {
                                <p class="text-muted small mb-2">📂 @project.SourcePath</p>
                            }
                            <div class="progress mb-2" style="height: 6px;">
                                <div class="progress-bar bg-success" style="width: @(project.Progress)%"></div>
                            </div>
                            <p class="small mb-0">
                                <span class="text-muted">@(project.Progress.ToString("F0"))% complete</span>
                                @if (project.CurrentPhase is not null)
                                {
                                    <span class="ms-2">· Current: @project.CurrentPhase</span>
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-transparent d-flex gap-2">
                            <button class="btn btn-sm btn-primary flex-grow-1" @onclick="() => ResumeProject(project.Id)">
                                Resume
                            </button>
                            @if (_confirmDeleteId == project.Id)
                            {
                                <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDeleteProject(project.Id)">
                                    Confirm
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmDeleteId = null">
                                    Cancel
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmDeleteId = project.Id">
                                    🗑
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5">
            <div class="mb-3" style="font-size: 2.5rem;">📁</div>
            <p>No saved projects yet.</p>
            <a href="/" class="btn btn-primary">Start a New Migration</a>
        </div>
    }
</div>

@code {
    private List<ProjectSummary> _projects = new();
    private bool _loading = true;
    private string? _confirmDeleteId;

    protected override async Task OnInitializedAsync()
    {
        _projects = await PersistenceService.ListProjectsAsync();
        _loading = false;
    }

    private async Task ResumeProject(string projectId)
    {
        var project = await PersistenceService.LoadProjectAsync(projectId);
        if (project is not null)
        {
            StateService.LoadProject(project);
            Navigation.NavigateTo("/dashboard");
        }
    }

    private async Task ConfirmDeleteProject(string projectId)
    {
        _confirmDeleteId = null;
        await PersistenceService.DeleteProjectAsync(projectId);
        _projects = await PersistenceService.ListProjectsAsync();
    }
}
