@page "/phase0/specify"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 0: Specify — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase">
        <PhaseContent>
            <div class="mb-4">
                <h5>📋 Specification Phase</h5>
                <p>
                    This phase transforms your discovery findings into detailed, field-level specifications,
                    user stories, and a comprehensive data dictionary. The Copilot assistant will generate
                    structured artifacts ready for development planning.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Generated Reports</h6>
                    <ul class="mb-0">
                        <li><strong>Field-Specifications.md</strong> — Detailed field-level specs for every entity</li>
                        <li><strong>User-Stories.md</strong> — User stories derived from discovered business processes</li>
                        <li><strong>Data-Dictionary.md</strong> — Comprehensive data dictionary with types, constraints, and relationships</li>
                    </ul>
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Use the chat panel on the right to interact with the specification assistant.
                        Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/phase0/discover" class="btn btn-outline-secondary">← Previous</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;

    protected override void OnInitialized()
    {
        if (StateService.CurrentProject is null)
            StateService.InitializeProject("New Migration Project");

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase0-specify");
    }

    private void StartPhase()
    {
        if (_phase is null) return;
        StateService.StartPhase(_phase.Id);
        StateHasChanged();
    }

    private void SkipPhase()
    {
        if (_phase is null) return;
        StateService.SkipPhase(_phase.Id);
        Navigation.NavigateTo("/phase0/validate");
    }

    private void CompletePhase()
    {
        if (_phase is null) return;
        StateService.CompletePhase(_phase.Id);
        Navigation.NavigateTo("/phase0/validate");
    }
}
