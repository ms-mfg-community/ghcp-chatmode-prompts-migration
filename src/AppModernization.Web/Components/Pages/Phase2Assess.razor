@page "/phase2/assess"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 2: Assess Project — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>🔬 Project Assessment</h5>
                <p>
                    This phase performs a deep technical assessment of your source project. The assistant
                    analyzes framework versions, dependencies, cloud readiness, and architectural patterns
                    to produce a comprehensive assessment report.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Assessment Covers</h6>
                    <ul class="mb-0">
                        <li>Framework version detection</li>
                        <li>Dependency analysis</li>
                        <li>Cloud readiness</li>
                        <li>Security assessment</li>
                        <li>Architecture analysis</li>
                        <li>Risk assessment</li>
                    </ul>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Assessment Report</h6>
                    <p class="text-muted mb-1">
                        <code>reports/Application-Assessment-Report.md</code>
                    </p>
                    <small class="text-muted">
                        The assessment report will be generated in the reports directory once the assessment completes.
                    </small>
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Use the chat panel on the right to interact with the assessment assistant.
                        Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/phase1/plan" class="btn btn-outline-secondary">← Previous</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;

    protected override async Task OnInitializedAsync()
    {
        if (StateService.CurrentProject is null)
            await StateService.InitializeProjectAsync("New Migration Project");

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase2-assess");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        var sourcePath = StateService.CurrentProject?.SourcePath;
        if (!string.IsNullOrWhiteSpace(sourcePath))
        {
            _autoPrompt = $"Perform a comprehensive assessment of the application at: {sourcePath}\n" +
                "Read the planning reports in reports/ for context.\n" +
                "Analyze the application structure, dependencies, and architecture.\n" +
                "Generate reports/Application-Assessment-Report.md with detailed findings.\n" +
                "Include risk assessment and migration effort estimates.";
        }
        else
        {
            _autoPrompt = "Perform a comprehensive assessment of the application.\n" +
                "Read the planning reports in reports/ for context.\n" +
                "Analyze the application structure, dependencies, and architecture.\n" +
                "Generate reports/Application-Assessment-Report.md with detailed findings.\n" +
                "Include risk assessment and migration effort estimates.";
        }
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase3/migrate");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase3/migrate");
    }
}
