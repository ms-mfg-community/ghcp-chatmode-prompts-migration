@page "/phase0/discover"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 0: Discover — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>🔍 Discovery Phase</h5>
                <p>
                    In this phase, the Copilot assistant will help you analyze your legacy codebase to
                    understand its structure, dependencies, and business logic before migration planning begins.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">What Discovery Does</h6>
                    <ul class="mb-0">
                        <li>Analyzes the source code structure and architecture</li>
                        <li>Maps end-to-end business processes</li>
                        <li>Identifies external dependencies and integrations</li>
                        <li>Extracts implicit business rules from code</li>
                        <li>Documents data flows and storage patterns</li>
                    </ul>
                </div>
            </div>

            @if (StateService.CurrentProject?.SourcePath is not null)
            {
                <div class="alert alert-info">
                    <strong>Source Path:</strong> @StateService.CurrentProject.SourcePath
                </div>
            }

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Click <strong>Get Started</strong> to begin analyzing the codebase.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/dashboard" class="btn btn-outline-secondary">
                    ← Dashboard
                </a>
                <div>
                    <button class="btn btn-outline-secondary me-2"
                            @onclick="SkipPhase">
                        Skip
                    </button>
                    <button class="btn btn-success"
                            @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;

    protected override void OnInitialized()
    {
        if (StateService.CurrentProject is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase0-discover");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        // If phase is already in progress (user navigated back), auto-prompt on load
        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        var reportsPath = StateService.GetCurrentProjectReportsPath();
        var reportsDir = reportsPath ?? "reports";
        var sourcePath = StateService.CurrentProject?.SourcePath;
        if (!string.IsNullOrWhiteSpace(sourcePath))
        {
            _autoPrompt = $"Analyze the legacy application at: {sourcePath}\n\n" +
                "Perform a full discovery:\n" +
                "1. Scan the codebase and identify all projects, forms, classes, and SQL scripts\n" +
                "2. Determine the application type (.NET Framework version, UI technology)\n" +
                "3. Map the architecture and component relationships\n" +
                "4. Extract business rules from code and stored procedures\n" +
                $"5. Document all findings in {reportsDir}/Legacy-Discovery-Report.md\n" +
                $"6. Document extracted business requirements in {reportsDir}/Business-Requirements.md\n" +
                $"7. Document process flows in {reportsDir}/Process-Maps.md\n\n" +
                $"Generate all reports as markdown files in the {reportsDir}/ directory.";
        }
        else
        {
            _autoPrompt = $"Start the discovery process. Scan the current workspace, identify the application type and architecture, extract business rules, and generate all discovery reports in the {reportsDir}/ directory.";
        }
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase0/specify");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase0/specify");
    }
}
