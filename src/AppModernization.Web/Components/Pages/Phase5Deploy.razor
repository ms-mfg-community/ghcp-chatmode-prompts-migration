@page "/phase5/deploy"
@rendermode InteractiveServer
@using AppModernization.Web.Models
@using AppModernization.Web.Components.Wizard
@inject Services.MigrationStateService StateService
@inject NavigationManager Navigation

<PageTitle>Phase 5: Deploy to Azure — App Modernization</PageTitle>

@if (_phase is not null)
{
    <PhasePage Phase="_phase" AutoPrompt="@_autoPrompt" WorkingDirectory="@_workingDirectory">
        <PhaseContent>
            <div class="mb-4">
                <h5>🚀 Deploy to Azure</h5>
                <p>
                    This phase deploys your migrated application and infrastructure to Azure.
                    Review the pre-flight checklist below before starting deployment.
                </p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Pre-Flight Checklist</h6>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-azcli" disabled>
                        <label class="form-check-label" for="chk-azcli">Azure CLI installed</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-login" disabled>
                        <label class="form-check-label" for="chk-login">Logged in to Azure</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-sub" disabled>
                        <label class="form-check-label" for="chk-sub">Subscription selected</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-infra" disabled>
                        <label class="form-check-label" for="chk-infra">Infrastructure validated</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-app" disabled>
                        <label class="form-check-label" for="chk-app">Application ready</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="chk-docker" disabled>
                        <label class="form-check-label" for="chk-docker">Docker running (if containers)</label>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title">Deployment Commands</h6>
                    <pre class="bg-dark text-light p-3 rounded mb-0"><code>azd init
azd up</code></pre>
                </div>
            </div>

            @if (_phase.Status == PhaseStatus.NotStarted)
            {
                <div class="text-center py-3">
                    <p class="text-muted mb-3">
                        Use the chat panel on the right to interact with the deployment assistant.
                        Click <strong>Get Started</strong> to begin.
                    </p>
                    <button class="btn btn-primary btn-lg" @onclick="StartPhase">
                        🚀 Get Started
                    </button>
                </div>
            }
        </PhaseContent>
        <PhaseActions>
            <div class="d-flex justify-content-between">
                <a href="/phase4/infra" class="btn btn-outline-secondary">← Previous</a>
                <div>
                    <button class="btn btn-outline-secondary me-2" @onclick="SkipPhase">Skip</button>
                    <button class="btn btn-success" @onclick="CompletePhase"
                            disabled="@(_phase.Status != PhaseStatus.InProgress)">
                        Complete & Continue →
                    </button>
                </div>
            </div>
        </PhaseActions>
    </PhasePage>
}
else
{
    <div class="text-center py-5">
        <h4 class="text-muted">No active project</h4>
        <p>Please start a new migration project first.</p>
        <a href="/" class="btn btn-primary">Go to Home</a>
    </div>
}

@code {
    private PhaseInfo? _phase;
    private string? _autoPrompt;
    private string? _workingDirectory;

    protected override async Task OnInitializedAsync()
    {
        if (StateService.CurrentProject is null)
            await StateService.InitializeProjectAsync("New Migration Project");

        _phase = StateService.GetPhases().FirstOrDefault(p => p.Id == "phase5-deploy");
        _workingDirectory = StateService.CurrentProject?.SourcePath;

        if (_phase?.Status == PhaseStatus.InProgress)
        {
            BuildAutoPrompt();
        }
    }

    private async Task StartPhase()
    {
        if (_phase is null) return;
        await StateService.StartPhaseAsync(_phase.Id);
        BuildAutoPrompt();
        StateHasChanged();
    }

    private void BuildAutoPrompt()
    {
        _autoPrompt = "Prepare deployment for the migrated application.\n" +
            "Read all reports in reports/ for context on the infrastructure and application.\n" +
            "Create an azure.yaml file for Azure Developer CLI (azd) support.\n" +
            "Guide me through the deployment steps.";
    }

    private async Task SkipPhase()
    {
        if (_phase is null) return;
        await StateService.SkipPhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase6/cicd");
    }

    private async Task CompletePhase()
    {
        if (_phase is null) return;
        await StateService.CompletePhaseAsync(_phase.Id);
        Navigation.NavigateTo("/phase6/cicd");
    }
}
